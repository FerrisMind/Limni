{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Limni",
  "version": "0.1.0",
  "identifier": "com.limni.browser",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Limni",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "decorations": false,
        "transparent": false,
        "titleBarStyle": "Overlay",
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/limni.ico",
      "icons/limni.svg",
      "icons/limni.icns",
      "icons/limni-icon_32x32.png",
      "icons/limni-icon_128x128.png",
      "icons/limni-icon_128x128@2x.png",
      "icons/limni-icon_Square30x30Logo.png",
      "icons/limni-icon_Square44x44Logo.png",
      "icons/limni-icon_Square71x71Logo.png",
      "icons/limni-icon_Square89x89Logo.png",
      "icons/limni-icon_Square107x107Logo.png",
      "icons/limni-icon_Square142x142Logo.png",
      "icons/limni-icon_Square150x150Logo.png",
      "icons/limni-icon_Square248x248Logo.png",
      "icons/limni-icon_Square310x310Logo.png",
      "icons/limni-icon_StoreLogo.png"
    ]
  }
}
